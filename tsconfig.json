{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@mehndi/database": ["../../packages/database"],
      "@mehndi/shared": ["../../packages/shared"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}